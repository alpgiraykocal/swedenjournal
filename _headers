# Netlify headers — security + caching
# Docs: https://docs.netlify.com/routing/headers/

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; object-src 'none'; upgrade-insecure-requests

# Versioned (CSS/JS via ?v=) and content-named (fonts/images) assets — cache forever.
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable
/assets/images/*
  Cache-Control: public, max-age=31536000, immutable
/assets/css/*
  Cache-Control: public, max-age=31536000, immutable
/assets/js/*
  Cache-Control: public, max-age=31536000, immutable

# Content JSON is unversioned — keep it fresh so edits publish promptly.
/assets/data/*
  Cache-Control: public, max-age=60, must-revalidate
