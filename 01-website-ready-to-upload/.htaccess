ErrorDocument 404 /404.html

# Serve ES modules with a JavaScript MIME type (site.js is type="module" and
# imports templates.mjs). Without this, Apache may serve .mjs as a generic type
# and the browser will refuse to execute the module.
<IfModule mod_mime.c>
  AddType text/javascript .mjs
  AddType text/javascript .js
</IfModule>

# Block raw local source photos if the workspace folder is uploaded by mistake
RedirectMatch 404 ^/assets/images/photos/

# Story clean URL redirects
RewriteEngine On
RewriteCond %{QUERY_STRING} ^slug=(.+)$
RewriteRule ^story/$ /stories/%1/ [R=301,L]
